POSTGRES_DB=messenger
POSTGRES_USER=messenger
POSTGRES_PASSWORD=messenger

PORT=8080
HOST_PORT=9080

DATABASE_URL=postgres://messenger:messenger@postgres:5432/messenger?sslmode=disable

UPLOADS_DIR=/app/uploads

# Push (FCM): path inside container; mount ./secrets -> /app/secrets
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=/app/secrets/firebase-service-account.json
